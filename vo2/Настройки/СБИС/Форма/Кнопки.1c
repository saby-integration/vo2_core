&НаКлиенте
Процедура	Диалог_ОтменаНажатие(Элемент)
	
	ЭтаФорма.Закрыть();
	
КонецПроцедуры

&НаКлиенте
Процедура	Диалог_ВыбратьНажатие(Элемент)
	
	#Если ТолстыйКлиентОбычноеПриложение Тогда
		КлючЭлементов = "ТекущаяСтрока";
	#Иначе
		КлючЭлементов = "ТекущиеДанные";
	#КонецЕсли
	ЭтаФорма.Закрыть(Элемент[КлючЭлементов].Идентификатор);
	
КонецПроцедуры

